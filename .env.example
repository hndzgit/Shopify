# Shopify Storefront API (Public)
SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
SHOPIFY_STOREFRONT_ACCESS_TOKEN="your-storefront-token"
PUBLIC_STOREFRONT_API_VERSION="2025-01"

# Shopify Admin API (Private)
SHOPIFY_ADMIN_ACCESS_TOKEN="shpat_your_admin_token"

# Authentication (NextAuth v5)
AUTH_SECRET="your-secret-key"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="password123"

# App Configuration
APP_URL="https://HeadlessStorefront.com"
NEXT_PUBLIC_APP_URL="https://HeadlessStorefront.com"
